---
import Layout from '../layouts/Layout.astro';

const title = 'Contact — Dhikrama';
const description = 'Contact Dhikrama for general portfolio inquiries, or visit each project website for project-specific inquiries.';
---

<Layout title={title} description={description} canonicalPath="/contact">
  <section class="hero">
    <div class="narrow stack-lg">
      <span class="eyebrow">Contact</span>
      <h1>Find the right contact path.</h1>
      <p class="lead">
        Use Dhikrama for general portfolio inquiries. For project-specific needs, contact the dedicated project directly.
      </p>
    </div>
  </section>

  <section class="section soft-section" aria-labelledby="contact-options">
    <div class="container grid grid-3">
      <article class="card">
        <h2 id="contact-options">Dhikrama</h2>
        <p>General portfolio inquiries, project introductions, and collaboration context.</p>
        <p><strong>Email:</strong> General contact information will be added here once the official channel is confirmed.</p>
      </article>
      <article class="card">
        <h2>Nagili</h2>
        <p>For logistics and transportation inquiries, please contact Nagili directly.</p>
        <a class="button primary" href="https://nagili.dhikrama.com" rel="noopener noreferrer">Visit Nagili</a>
      </article>
      <article class="card">
        <h2>Boringan</h2>
        <p>For Boringan-related inquiries, please visit Boringan.</p>
        <a class="button primary" href="https://boringan.com" rel="noopener noreferrer">Visit Boringan</a>
      </article>
    </div>
  </section>

  <section class="section" aria-labelledby="contact-note">
    <div class="narrow panel stack">
      <span class="eyebrow">Note</span>
      <h2 id="contact-note">Project websites are the best place for project-specific details.</h2>
      <p>
        Dhikrama is designed as a portfolio and umbrella-brand website. It links to the dedicated websites where each project can explain its own service details, product updates, and contact flow.
      </p>
    </div>
  </section>
</Layout>
