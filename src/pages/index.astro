---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';

const title = 'Dhikrama — Independent Project & Venture Portfolio';
const description = 'Dhikrama is an independent portfolio of practical products, services, and ventures, including Nagili and Boringan.';
---

<Layout title={title} description={description} canonicalPath="/">
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Independent portfolio brand</span>
        <h1>Practical projects, services, and ventures under one clear umbrella.</h1>
        <p class="lead">
          Dhikrama is an independent portfolio of digital products, services, and ventures built to solve practical problems in the real world.
        </p>
        <div class="hero-actions" aria-label="Primary actions">
          <a class="button primary" href="/projects">Explore projects</a>
          <a class="button secondary" href="/about">About Dhikrama</a>
        </div>
      </div>
      <aside class="panel stack" aria-labelledby="portfolio-summary">
        <span class="eyebrow">Portfolio snapshot</span>
        <h2 id="portfolio-summary">Founder-led and independently managed.</h2>
        <p>
          Dhikrama acts as a trust layer, credibility layer, and navigation hub for independent projects with their own websites and service focus.
        </p>
        <ul class="plain-list">
          <li>Nagili for logistics and transportation.</li>
          <li>Boringan as an independent project in the portfolio.</li>
          <li>Future projects can be added without changing the overall structure.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section soft-section" aria-labelledby="what-is-dhikrama">
    <div class="narrow stack-lg">
      <span class="eyebrow">What Dhikrama is</span>
      <h2 id="what-is-dhikrama">An umbrella brand for independent projects.</h2>
      <p class="lead">
        Dhikrama is a founder-led portfolio of independent projects, including logistics, digital services, and practical technology products.
      </p>
      <p>
        Each project may operate with its own brand, website, and service model. Dhikrama provides a clear way to understand how these projects relate to one another without presenting itself as a formal corporate group.
      </p>
    </div>
  </section>

  <section class="section" aria-labelledby="featured-projects">
    <div class="container stack-lg">
      <div class="stack">
        <span class="eyebrow">Featured projects</span>
        <h2 id="featured-projects">Independent brands connected through Dhikrama.</h2>
        <p class="lead">Visit each dedicated project website for product-specific or service-specific information.</p>
      </div>
      <div class="grid grid-2">
        {projects.map((project) => (
          <article class="card project-card">
            <div class="project-meta">
              {project.categories.map((category) => <span class="tag">{category}</span>)}
            </div>
            <h3>{project.name}</h3>
            <p>{project.summary}</p>
            <div class="button-row">
              <a class="button secondary" href={`/projects/${project.slug}`}>View profile</a>
              <a class="button primary" href={project.url} rel="noopener noreferrer">{project.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section soft-section" aria-labelledby="principles">
    <div class="container grid grid-2">
      <div class="stack">
        <span class="eyebrow">Operating principles</span>
        <h2 id="principles">Built to stay practical, transparent, and focused.</h2>
        <p>
          Dhikrama keeps its role clear: introduce the portfolio, explain relationships, and guide visitors to the right project website.
        </p>
      </div>
      <ol class="numbered">
        <li>
          <strong>Separate focus.</strong><br />
          Project-specific commercial keywords and service details belong on each project website.
        </li>
        <li>
          <strong>Clear relationships.</strong><br />
          Nagili and Boringan are presented as separate projects within the Dhikrama portfolio.
        </li>
        <li>
          <strong>No overclaiming.</strong><br />
          Dhikrama uses portfolio and umbrella-brand language, not formal corporate group language.
        </li>
      </ol>
    </div>
  </section>

  <section class="section" aria-labelledby="contact-cta">
    <div class="narrow panel stack">
      <span class="eyebrow">Get in touch</span>
      <h2 id="contact-cta">Looking for the right project or contact path?</h2>
      <p>
        Contact Dhikrama for general portfolio inquiries. For logistics and transportation needs, visit Nagili directly.
      </p>
      <div class="button-row">
        <a class="button primary" href="/contact">Contact Dhikrama</a>
        <a class="button secondary" href="https://nagili.dhikrama.com" rel="noopener noreferrer">Go to Nagili</a>
      </div>
    </div>
  </section>
</Layout>
