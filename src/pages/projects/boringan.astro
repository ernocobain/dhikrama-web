---
import Layout from '../../layouts/Layout.astro';

const title = 'Boringan — Project in the Dhikrama Portfolio';
const description = 'Boringan is an independent project in the Dhikrama portfolio.';
const projectSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: 'Boringan',
  url: 'https://dhikrama.com/projects/boringan',
  sameAs: 'https://boringan.com',
  description,
  isPartOf: {
    '@type': 'CreativeWork',
    name: 'Dhikrama Project Portfolio',
    url: 'https://dhikrama.com',
  },
};
---

<Layout title={title} description={description} canonicalPath="/projects/boringan" structuredData={projectSchema}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Project profile</span>
        <h1>Boringan</h1>
        <p class="lead">
          Boringan is an independent project in the Dhikrama portfolio.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="https://boringan.com" rel="noopener noreferrer">Visit Boringan</a>
          <a class="button secondary" href="/projects">Back to projects</a>
        </div>
      </div>
      <aside class="panel stack">
        <span class="eyebrow">Relationship</span>
        <h2>Boringan is part of the Dhikrama project portfolio.</h2>
        <p>
          This page is a portfolio-level profile. Update the description when the exact service or product category should be published.
        </p>
      </aside>
    </div>
  </section>

  <section class="section soft-section" aria-labelledby="boringan-summary">
    <div class="narrow panel stack">
      <h2 id="boringan-summary">Project summary</h2>
      <p>
        Boringan is an independent project under the Dhikrama portfolio. Update this description based on the actual service or product category.
      </p>
      <p>
        Like other Dhikrama portfolio projects, Boringan may operate with its own brand, website, and service focus.
      </p>
      <a class="button primary" href="https://boringan.com" rel="noopener noreferrer">Open the official Boringan website</a>
    </div>
  </section>
</Layout>
