---
import { projects } from '../data/projects';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const frontmatter = Astro.props.frontmatter || {};
const {
  title = frontmatter.title || 'Dhikrama — Independent Project & Venture Portfolio',
  description = frontmatter.description || 'Dhikrama is an independent portfolio of practical products, services, and ventures, including Nagili and Boringan.',
  canonicalPath = Astro.url.pathname,
  ogType = 'website',
  structuredData = [],
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://dhikrama.com';
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImage = new URL('/og-image.png', siteUrl).toString();
const structuredDataItems = Array.isArray(structuredData) ? structuredData : [structuredData];
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Dhikrama',
  url: siteUrl,
  description,
  inLanguage: 'en',
};
const portfolioSchema = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: 'Dhikrama Project Portfolio',
  url: siteUrl,
  description: 'An independent portfolio brand for practical products, services, and ventures.',
  hasPart: projects.map((project) => ({
    '@type': 'CreativeWork',
    name: project.name,
    url: `${siteUrl}/projects/${project.slug}`,
    sameAs: project.url,
    description: project.summary,
  })),
};
const allStructuredData = [websiteSchema, portfolioSchema, ...structuredDataItems].filter(Boolean);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <meta property="og:site_name" content="Dhikrama" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(allStructuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="site-header">
      <nav class="nav" aria-label="Primary navigation">
        <a class="brand" href="/" aria-label="Dhikrama homepage">
          <span class="brand-mark">D</span>
          <span>Dhikrama</span>
        </a>
        <div class="nav-links">
          <a href="/about">About</a>
          <a href="/projects">Projects</a>
          <a href="/contact">Contact</a>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <section aria-labelledby="footer-brand">
          <h2 id="footer-brand">Dhikrama</h2>
          <p>Dhikrama is an independent portfolio of projects and services.</p>
          <p class="footer-note">Each project may operate with its own brand, website, and service focus.</p>
        </section>
        <section aria-labelledby="footer-site-links">
          <h2 id="footer-site-links">Website</h2>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/projects">Projects</a></li>
            <li><a href="/contact">Contact</a></li>
            <li><a href="/legal">Legal / Disclaimer</a></li>
          </ul>
        </section>
        <section aria-labelledby="footer-project-links">
          <h2 id="footer-project-links">Projects</h2>
          <ul>
            <li><a href="/projects/nagili">Nagili profile</a></li>
            <li><a href="https://nagili.dhikrama.com" rel="noopener noreferrer">Nagili website</a></li>
            <li><a href="/projects/boringan">Boringan profile</a></li>
            <li><a href="https://boringan.com" rel="noopener noreferrer">Boringan website</a></li>
          </ul>
        </section>
        <section aria-labelledby="footer-legal-links">
          <h2 id="footer-legal-links">Policies</h2>
          <ul>
            <li><a href="/nagili/privacy">Nagili Privacy Policy</a></li>
            <li><a href="/nagili/terms">Nagili Terms of Service</a></li>
          </ul>
        </section>
      </div>
      <div class="footer-bottom">
        <p>© {new Date().getFullYear()} Dhikrama. Independent portfolio brand.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f8fafc;
    --surface: #ffffff;
    --surface-muted: #eef3f8;
    --ink: #172033;
    --muted: #5d687b;
    --soft: #d9e1ec;
    --brand: #24436f;
    --brand-strong: #142942;
    --accent: #d99845;
    --accent-soft: #fff4e4;
    --radius: 22px;
    --shadow: 0 24px 80px rgba(20, 41, 66, 0.12);
  }

  * { box-sizing: border-box; }

  html {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--ink);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    line-height: 1.6;
    background:
      radial-gradient(circle at top left, rgba(217, 152, 69, 0.16), transparent 34rem),
      radial-gradient(circle at top right, rgba(36, 67, 111, 0.11), transparent 32rem),
      var(--bg);
  }

  a { color: var(--brand); text-decoration: none; }
  a:hover { text-decoration: underline; }
  a:focus-visible, button:focus-visible { outline: 3px solid var(--accent); outline-offset: 3px; }
  img, svg { max-width: 100%; }

  h1, h2, h3 { line-height: 1.12; margin: 0; color: var(--brand-strong); }
  h1 { font-size: clamp(2.4rem, 7vw, 5rem); letter-spacing: -0.06em; }
  h2 { font-size: clamp(1.8rem, 4vw, 3rem); letter-spacing: -0.04em; }
  h3 { font-size: 1.2rem; letter-spacing: -0.02em; }
  p { margin: 0; color: var(--muted); }

  .skip-link {
    position: absolute;
    left: 1rem;
    top: 1rem;
    z-index: 1000;
    transform: translateY(-200%);
    padding: 0.75rem 1rem;
    border-radius: 999px;
    background: var(--brand-strong);
    color: #fff;
    font-weight: 700;
  }
  .skip-link:focus { transform: translateY(0); }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(217, 225, 236, 0.78);
    background: rgba(248, 250, 252, 0.88);
    backdrop-filter: blur(16px);
  }

  .nav {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand, .nav-links { display: flex; align-items: center; }
  .brand { gap: 0.75rem; font-weight: 800; color: var(--brand-strong); }
  .brand:hover { text-decoration: none; }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 14px;
    background: var(--brand-strong);
    color: #fff;
    box-shadow: 0 12px 30px rgba(20, 41, 66, 0.2);
  }

  .nav-links { gap: 0.3rem; flex-wrap: wrap; justify-content: flex-end; }
  .nav-links a {
    padding: 0.65rem 0.85rem;
    border-radius: 999px;
    color: var(--muted);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .nav-links a:hover { background: var(--surface-muted); color: var(--brand-strong); text-decoration: none; }

  main { overflow: hidden; }
  main > h1,
  main > h2,
  main > h3,
  main > p,
  main > ul,
  main > ol,
  main > hr {
    width: min(860px, calc(100% - 2rem));
    margin-left: auto;
    margin-right: auto;
  }
  main > h1 { padding-top: 4rem; margin-bottom: 1.25rem; }
  main > h2 { margin-top: 2.5rem; margin-bottom: 1rem; font-size: clamp(1.45rem, 3vw, 2.1rem); }
  main > h3 { margin-top: 1.75rem; margin-bottom: 0.75rem; }
  main > p, main > ul, main > ol { margin-top: 1rem; }
  main > ul, main > ol { color: var(--muted); }
  main > hr { margin-top: 2rem; margin-bottom: 2rem; border: 0; border-top: 1px solid var(--soft); }
  main > p:last-child,
  main > ul:last-child,
  main > ol:last-child { margin-bottom: 4rem; }
  .section { padding: clamp(3.5rem, 8vw, 7rem) 0; }
  .container { width: min(1120px, calc(100% - 2rem)); margin: 0 auto; }
  .narrow { width: min(820px, calc(100% - 2rem)); margin: 0 auto; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--soft);
    border-radius: 999px;
    background: rgba(255,255,255,0.72);
    color: var(--brand);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .lead { font-size: clamp(1.08rem, 2vw, 1.35rem); color: #3f4a5c; }
  .stack { display: grid; gap: 1.25rem; }
  .stack-lg { display: grid; gap: 2rem; }
  .grid { display: grid; gap: 1.25rem; }
  .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }

  .hero { padding: clamp(4.5rem, 11vw, 8rem) 0 clamp(3.5rem, 8vw, 6rem); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr); gap: clamp(2rem, 6vw, 5rem); align-items: center; }
  .hero-copy { display: grid; gap: 1.5rem; }
  .hero-actions, .button-row { display: flex; gap: 0.85rem; flex-wrap: wrap; align-items: center; }
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1.1rem;
    border-radius: 999px;
    font-weight: 800;
    border: 1px solid transparent;
  }
  .button.primary { background: var(--brand-strong); color: #fff; box-shadow: 0 16px 34px rgba(20, 41, 66, 0.18); }
  .button.secondary { background: var(--surface); color: var(--brand-strong); border-color: var(--soft); }
  .button:hover { transform: translateY(-1px); text-decoration: none; }

  .panel, .card {
    border: 1px solid rgba(217, 225, 236, 0.94);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.84);
    box-shadow: var(--shadow);
  }
  .panel { padding: clamp(1.4rem, 4vw, 2rem); }
  .card { padding: 1.4rem; display: grid; gap: 1rem; box-shadow: 0 14px 40px rgba(20, 41, 66, 0.08); }
  .card:hover { border-color: rgba(36, 67, 111, 0.28); }
  .project-card { min-height: 100%; }
  .project-meta { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag { padding: 0.35rem 0.65rem; border-radius: 999px; background: var(--surface-muted); color: var(--brand); font-size: 0.82rem; font-weight: 800; }
  .soft-section { background: linear-gradient(180deg, rgba(255,255,255,0.5), rgba(238,243,248,0.7)); border-block: 1px solid rgba(217,225,236,0.76); }
  .numbered { counter-reset: item; list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .numbered li { counter-increment: item; position: relative; padding-left: 3.2rem; }
  .numbered li::before {
    content: counter(item);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--accent-soft);
    color: #8d5818;
    font-weight: 900;
  }
  .plain-list { margin: 0; padding-left: 1.2rem; color: var(--muted); }
  .plain-list li + li { margin-top: 0.45rem; }

  .site-footer { border-top: 1px solid var(--soft); background: #101b2b; color: #d7deea; }
  .site-footer h2 { color: #fff; font-size: 1rem; letter-spacing: 0; margin-bottom: 0.8rem; }
  .site-footer p, .site-footer a, .site-footer li { color: #c2cad7; }
  .site-footer a:hover { color: #fff; }
  .footer-grid { width: min(1120px, calc(100% - 2rem)); margin: 0 auto; padding: 3rem 0; display: grid; grid-template-columns: 1.5fr repeat(3, 1fr); gap: 2rem; }
  .footer-grid ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.45rem; }
  .footer-note { margin-top: 0.7rem; }
  .footer-bottom { width: min(1120px, calc(100% - 2rem)); margin: 0 auto; padding: 1rem 0 1.5rem; border-top: 1px solid rgba(255,255,255,0.12); }

  @media (max-width: 820px) {
    .hero-grid, .grid-2, .grid-3, .footer-grid { grid-template-columns: 1fr; }
    .nav { align-items: flex-start; flex-direction: column; padding: 0.9rem 0; }
    .nav-links { justify-content: flex-start; }
    .nav-links a { padding-left: 0; padding-right: 0.8rem; }
  }
</style>
